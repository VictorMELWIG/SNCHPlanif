<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="snchbilletterie.controller.TrainController">

    <top>
        <VBox spacing="8" style="-fx-background-color: white;">
            <padding>
                <Insets top="12" right="12" bottom="6" left="12"/>
            </padding>
            <Label text="Gestion des trains"
                   style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
            <Separator/>
        </VBox>
    </top>

    <center>
        <VBox spacing="12">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12"/>
            </padding>

            <!-- TABLE centrée -->
            <HBox alignment="CENTER">
                <TableView fx:id="table" prefHeight="320" maxWidth="520">
                    <columns>
                        <TableColumn fx:id="colId" text="ID" prefWidth="60" maxWidth="80"/>
                        <TableColumn fx:id="colNumero" text="Numéro train" prefWidth="220" maxWidth="240"/>
                        <TableColumn fx:id="colType" text="Type" prefWidth="220" maxWidth="240"/>
                    </columns>
                </TableView>
            </HBox>

            <!-- FORMULAIRE centré -->
            <HBox alignment="CENTER">
                <GridPane hgap="10" vgap="10" maxWidth="520">
                    <columnConstraints>
                        <ColumnConstraints minWidth="140"/>
                        <ColumnConstraints prefWidth="380"/>
                    </columnConstraints>

                    <Label text="Numéro train :" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="tfNumero" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Type train :" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="cbType" promptText="Choisir..." GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                </GridPane>
            </HBox>

            <!-- BOUTONS -->
            <HBox spacing="10" alignment="CENTER">
                <Button text="Ajouter" onAction="#add" minWidth="90"/>
                <Button text="Modifier" onAction="#update" minWidth="90"/>
                <Button text="Supprimer" onAction="#delete" minWidth="90"/>
                <Button text="Rafraîchir" onAction="#refresh" minWidth="90"/>
                <Button text="Vider" onAction="#clearForm" minWidth="90"/>
                <Button text="Retour" onAction="#goBack" minWidth="90"/>
            </HBox>

            <HBox alignment="CENTER">
                <Label fx:id="lblInfo" textFill="red"/>
            </HBox>

        </VBox>
    </center>
</BorderPane>
